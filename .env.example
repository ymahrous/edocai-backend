# Neon Database (Postgres)
DATABASE_URL=postgresql://user:password@ep-cool-name-12345.us-east-2.aws.neon.tech/neondb?sslmode=require

# Upstash (Redis)
UPSTASH_REDIS_ENDPOINT=us1-ultimate-gecko-12345.upstash.io
UPSTASH_REDIS_PASSWORD=your_upstash_password

# Supabase Storage
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_BUCKET_NAME=your_bucket_name

# Gemini API Key
GEMINI_API_KEY=your_google_api_key_here
SECRET_KEY=your_secret_key_here

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
STRIPE_PRICE_ID_PRO_MONTHLY=your_stripe_price_id_for_pro_monthly
STRIPE_PRICE_ID_PRO_ANNUAL=your_stripe_price_id_for_pro_annual

# Frontend URL
FRONTEND_URL=your_frontend_url_here

# QuickBooks API Credentials
QB_CLIENT_ID=your_intuit_client_id
QB_CLIENT_SECRET=your_intuit_client_secret
QB_REDIRECT_URI=http://localhost:8000/api/v1/quickbooks/callback
QB_ENVIRONMENT=sandbox